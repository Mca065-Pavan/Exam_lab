pipeline {
    agent any

    environment {
        DOCKER_HUB_USER = 'pavan'
        APP_NAME = 'java-cicd-app'
        IMAGE_TAG = "${DOCKER_HUB_USER}/${APP_NAME}:${BUILD_NUMBER}"
        LATEST_TAG = "${DOCKER_HUB_USER}/${APP_NAME}:latest"
        KUBECONFIG = '/home/mca/.kube/config'
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Mca065-Pavan/Exam_lab.git', branch: 'main'
            }
        }

        stage('Maven Build') {
            steps {
                sh 'cd java-cicd-project && mvn clean package -DskipTests -B'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'cd java-cicd-project && docker build -t ${IMAGE_TAG} -t ${LATEST_TAG} .'
            }
        }

        stage('Docker Hub Push') {
            steps {
                withCredentials([usernamePassword(credentialsId: 'dockerhub-creds', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh 'echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin'
                    sh 'docker push ${IMAGE_TAG}'
                    sh 'docker push ${LATEST_TAG}'
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh '''
                    cd java-cicd-project
                    minikube docker-env --shell=bash > /tmp/minikube-env.sh
                    eval $(minikube docker-env)
                    docker build -t ${LATEST_TAG} .
                    kubectl apply -f k8s-deployment.yaml
                    kubectl set image deployment/java-cicd-app java-cicd-app=${LATEST_TAG} --record
                    kubectl rollout status deployment/java-cicd-app --timeout=120s
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                    kubectl get pods -l app=java-cicd-app
                    kubectl get svc java-cicd-service
                '''
            }
        }
    }

    post {
        success {
            echo 'Pipeline executed successfully!'
        }
        failure {
            echo 'Pipeline failed!'
        }
    }
}
