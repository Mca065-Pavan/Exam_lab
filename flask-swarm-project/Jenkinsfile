pipeline {
    agent any

    environment {
        APP_NAME = 'flask-swarm-app'
        IMAGE_TAG = "${APP_NAME}:${BUILD_NUMBER}"
        LATEST_TAG = "${APP_NAME}:latest"
    }

    stages {
        stage('Checkout') {
            steps {
                git url: 'https://github.com/Mca065-Pavan/Exam_lab.git', branch: 'main'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'cd flask-swarm-project && docker build -t ${IMAGE_TAG} -t ${LATEST_TAG} .'
            }
        }

        stage('Deploy to Docker Swarm') {
            steps {
                sh '''
                    cd flask-swarm-project
                    docker service rm flaskapp_flask-app 2>/dev/null || true
                    docker stack deploy -c docker-compose.yml flaskapp
                    sleep 10
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                    docker service ls
                    docker service ps flaskapp_flask-app
                    curl -s http://127.0.0.1:5000 | head -5
                '''
            }
        }
    }

    post {
        success {
            echo 'Flask Swarm Pipeline executed successfully!'
        }
        failure {
            echo 'Flask Swarm Pipeline failed!'
        }
    }
}
